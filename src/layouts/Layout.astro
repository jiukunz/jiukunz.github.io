---
interface Props {
  title?: string;
}
const { title = 'jiukun' } = Astro.props;
---

<!doctype html>
<html lang="zh" data-lang="zh" data-theme="light">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="jiukun — Independent Designer & Developer" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>{title}</title>
</head>
<body>
  <slot />
  <script is:inline>
    // Initialize theme from localStorage or system preference
    (function() {
      const stored = localStorage.getItem('theme');
      if (stored) {
        document.documentElement.setAttribute('data-theme', stored);
      } else if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
        document.documentElement.setAttribute('data-theme', 'dark');
      }
    })();
    // Initialize language from localStorage or browser language
    (function() {
      const stored = localStorage.getItem('lang');
      if (stored) {
        document.documentElement.setAttribute('data-lang', stored);
      } else if (navigator.language.startsWith('en')) {
        document.documentElement.setAttribute('data-lang', 'en');
      }
    })();
  </script>
</body>
</html>

<style is:global>
  *,
  *::before,
  *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  :root {
    --color-bg: #ffffff;
    --color-text: #1a1a1a;
    --color-text-secondary: #666666;
    --color-border: #e5e5e5;
    --color-card-bg: #f5f5f5;
    --color-card-hover: #eeeeee;
    --color-accent: #1a1a1a;
    --sidebar-bg: #1a1a1a;
    --sidebar-text: #e5e5e5;
    --sidebar-text-secondary: #999999;
    --sidebar-border: #333333;
    --font-sans: system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
  }

  [data-theme="dark"] {
    --color-bg: #0a0a0a;
    --color-text: #e5e5e5;
    --color-text-secondary: #999999;
    --color-border: #2a2a2a;
    --color-card-bg: #141414;
    --color-card-hover: #1f1f1f;
    --color-accent: #e5e5e5;
  }

  html {
    font-family: var(--font-sans);
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
  }

  body {
    background: var(--color-bg);
    color: var(--color-text);
    min-height: 100vh;
  }

  .page {
    display: grid;
    grid-template-columns: 38% 1fr;
    min-height: 100vh;
  }

  @media (max-width: 768px) {
    .page {
      grid-template-columns: 1fr;
    }
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  /* Bilingual toggle */
  [data-lang="zh"] .lang-en { display: none !important; }
  [data-lang="en"] .lang-zh { display: none !important; }

  .main {
    padding: 4rem 3rem;
    background: var(--color-bg);
    color: var(--color-text);
    max-width: 640px;
  }

  @media (max-width: 768px) {
    .main {
      padding: 2rem 1.5rem;
    }
  }
</style>
